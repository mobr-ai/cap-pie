# Virtuoso Configuration
# Host and credentials for the Virtuoso triple store
TRIPLESTORE_HOST=virtuoso
TRIPLESTORE_PORT=8890
TRIPLESTORE_USER=dba
TRIPLESTORE_PASSWORD=your_secret_password_here
TRIPLESTORE_TIMEOUT=300
TRIPLESTORE_ENDPOINT=/sparql
SPARQL_UPDATE=true

# Cardano Knowledge Graph Configuration
# URI for the Cardano ontology graph in Virtuoso
CARDANO_GRAPH=https://mobr.ai/ont/cardano
ONTOLOGY_PATH="src/ontologies/cardano.ttl"

# LLM Configuration
LLM_ONTOLOGY_PATH="src/ontologies/cardano.ttl"
MODEL_CONTEXT_CAP=40
CHAR_PER_TOKEN=4

# OpenTelemetry Configuration
# OTLP exporter endpoint for telemetry data
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Service name for telemetry identification
OTEL_SERVICE_NAME=cap

REFER_CLASSIFIER_DATASET_PATH=datasets/refer_classifier_examples.en.jsonl
RENDER_CLASSIFIER_DATASET_PATH=datasets/render_classifier_examples.en.jsonl

# postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secret_password_here
POSTGRES_DB=cap
DATABASE_URL=postgresql+psycopg2://postgres:your_secret_password_here@postgres:5432/cap

# Logging
ENABLE_TRACING=True
LOG_LEVEL=INFO

# CAP configuration
CAP_HOST=localhost
CAP_PORT=8000
PUBLIC_BASE_URL=https://cap.mobr.ai

# llm
# Default: OpenAI API
LLM_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
FEWSHOT_TOP_N=10


# Optional override for any OpenAI-compatible local server (vLLM, LM Studio, Ollama proxy, etc.)
LLM_BASE_URL=http://vllm:8000
LLM_API_KEY=
LLM_MODEL_NAME=Qwen/Qwen3-8B-AWQ

# If LLM_MODEL_NAME is set, it overrides OPENAI_MODEL.
# MUST also set LLM_BASE_URL with vllm though

NL_TO_SPARQL_PROMPT=""
CHART_PROMPT="You are the Cardano Analytics Platform chart analyzer."
CONTEXTUALIZE_PROMPT="Based on the above information, provide a clear and helpful answer to the user's question."

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Mailing
RESEND_API_KEY=your_key_here

# Artifact/widget sharing
SHARE_IMAGE_DIR=/var/lib/cap/share-images
SHARE_IMAGE_TTL_DAYS=7
SHARE_IMAGE_MAX_BYTES=8388608